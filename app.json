{
  "expo": {
    "name": "Arise Up",
    "slug": "arise-up",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0A0A12"
    },
    "android": {
      "package": "com.ariseup.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A0A12"
      },
      "permissions": [
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "ACCESS_NETWORK_STATE",
        "INTERNET"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ariseup.app"
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.6.10"
          },
          "ios": { "useFrameworks": "static" }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "55c942ba-89a2-4bdf-aba0-e2385deb407c"
      }
    }
  },
  "react-native-google-mobile-ads": {
    "android_app_id": "ca-app-pub-2414187213184434~9941896204",
    "ios_app_id": "ca-app-pub-2414187213184434~9941896204"
  }
}
